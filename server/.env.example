# ============================================================
# Antigravity Model — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5000

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=antigravity_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Secret (change this in production!)
JWT_SECRET=antigravity_super_secret_key_2024

# Twilio (Mock — replace with real keys for production)
TWILIO_ACCOUNT_SID=AC_MOCK_SID
TWILIO_AUTH_TOKEN=MOCK_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+15551234567

# SendGrid (Mock — replace with real keys for production)
SENDGRID_API_KEY=SG.MOCK_API_KEY
SENDGRID_FROM_EMAIL=noreply@antigravity.university.edu
